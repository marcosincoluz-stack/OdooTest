<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Lista (Tree) -->
    <record id="view_incoluz_zona_tree" model="ir.ui.view">
        <field name="name">incoluz.entregas_montajes.zona.tree</field>
        <field name="model">incoluz_entregas_montajes.zona</field>
        <field name="arch" type="xml">
            <tree string="Zonas de Montaje">
                <header/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Vista de Formulario -->
    <record id="view_incoluz_zona_form" model="ir.ui.view">
        <field name="name">incoluz.entregas_montajes.zona.form</field>
        <field name="model">incoluz_entregas_montajes.zona</field>
        <field name="arch" type="xml">
            <form string="Zona de Montaje">
                <header/>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: Zona Norte / Montador Juan"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas">
                            <field name="notes" placeholder="Información adicional..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de Búsqueda -->
    <record id="view_incoluz_zona_search" model="ir.ui.view">
        <field name="name">incoluz.entregas_montajes.zona.search</field>
        <field name="model">incoluz_entregas_montajes.zona</field>
        <field name="arch" type="xml">
            <search string="Buscar Zonas">
                <field name="name"/>
                <filter string="Archivados" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_incoluz_zona" model="ir.actions.act_window">
        <field name="name">Zonas de Montaje</field>
        <field name="res_model">incoluz_entregas_montajes.zona</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea la primera zona de montaje
            </p>
        </field>
    </record>

    <!-- Menús -->
    <menuitem id="menu_incoluz_root" name="IncoRutas" sequence="10"/>
    <menuitem id="menu_incoluz_config" name="Configuración" parent="menu_incoluz_root" sequence="100"/>
    <menuitem id="menu_incoluz_zona" name="Zonas de Montaje" parent="menu_incoluz_config" action="action_incoluz_zona" sequence="10"/>
</odoo>
