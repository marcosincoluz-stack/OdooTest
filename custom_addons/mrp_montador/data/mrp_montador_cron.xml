<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Motor de Sincronización Automática en Segundo Plano -->
        <record id="ir_cron_sync_picking_supabase" model="ir.cron">
            <field name="name">Sync App: Procesar Albaranes Pendientes</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_pending_jobs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
